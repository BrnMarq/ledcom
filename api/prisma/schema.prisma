generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String?
  googleId  String?   @unique
  accounts  Account[]
  createdAt DateTime  @default(now())
}

model Account {
  id           Int           @id @default(autoincrement())
  name         String
  symbol       String        @default("USD")
  user         User          @relation(fields: [userId], references: [id])
  userId       Int
  transactions Transaction[]
  createdAt    DateTime      @default(now())

  @@unique([name, userId])
}

enum TransactionType {
  NEEDS
  WANTS
  SAVINGS
}

enum TransactionSource {
  MANUAL
  BOT
}

enum TransactionFlow {
  IN
  OUT
}

model Transaction {
  id          Int      @id @default(autoincrement())
  accountId   Int
  account     Account  @relation(fields: [accountId], references: [id])
  totalValue  Float    @default(0) // Total fiat impact
  type        TransactionType
  flow        TransactionFlow @default(OUT)
  date        DateTime @default(now())
  
  // Updated Context Fields
  context     String?
  status      String   @default("PENDING_CONTEXT")
  source      TransactionSource @default(MANUAL)
  
  media       TransactionMedia[]
  items       TransactionItem[]
}

model TransactionItem {
  id            Int         @id @default(autoincrement())
  transactionId Int
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  
  name          String
  quantity      Float
  unitPrice     Float
  totalPrice    Float
}

model TransactionMedia {
  id            Int         @id @default(autoincrement())
  url           String
  type          String      // AUDIO, IMAGE
  transactionId Int
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  createdAt     DateTime    @default(now())
}

model DailyPrice {
  id        Int      @id @default(autoincrement())
  symbol    String
  provider  String
  price     Float
  date      DateTime @db.Date
  
  @@unique([symbol, date, provider])
}
